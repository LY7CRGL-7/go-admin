# ========================================
# 配置模板 - 使用者请复制为 config.yaml 并修改
# ========================================

server:
  http:
    addr: 0.0.0.0:8080
    timeout: 10s
  grpc:
    addr: 0.0.0.0:9090
    timeout: 10s

data:
  database:
    driver: postgres    # mysql 或 postgres
    source: "host=localhost port=5432 user=YOUR_USER password=YOUR_PASSWORD dbname=YOUR_DB sslmode=disable timezone=Asia/Shanghai"
    # MySQL 示例：
    # driver: mysql
    # source: "user:password@tcp(localhost:3306)/dbname?charset=utf8mb4&parseTime=True&loc=Local"
    max_idle: 10
    max_open: 100
    max_lifetime: 3600s
  redis:
    addr: localhost:6379
    password: ""
    db: 0
    dial_timeout: 5s
    read_timeout: 3s
    write_timeout: 3s

auth:
  jwt_secret: CHANGE-THIS-TO-A-RANDOM-256-BIT-SECRET
  token_expire: 24h
  refresh_expire: 168h
  init_admin:
    username: admin
    password: CHANGE-THIS-TO-STRONG-PASSWORD
    nickname: 系统管理员

tenant:
  enabled: false
  default_tenant_code: default
