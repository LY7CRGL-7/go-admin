# ========================================
# 模板项目 .gitignore 配置
# 使用者可以根据需要添加更多忽略规则
# ========================================

# 二进制文件
bin/
*.exe
*.dll
*.so
*.dylib

# Go 相关
vendor/
*.test
*.out

# Proto 生成文件（模板项目需要提交，确保 clone 后直接能编译）
# **/*.pb.go
# **/*.pb.gw.go

# Wire 生成文件（模板项目需要提交，确保依赖注入可用）
# **/wire_gen.go

# 配置文件（包含敏感信息，只提交 .example 模板）
config.yaml
*.local.yaml
*.local.json
config.local.*
.env

# 日志文件
logs/
*.log

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# 数据库文件
*.db
*.sqlite
*.sqlite3

# 证书和密钥
*.pem
*.key
*.crt
*.p12
*.pfx

# Docker
.docker/

# 临时文件
tmp/
temp/
*.tmp
*.bak
*.swp

# 系统文件
.Spotlight-V100
.Trashes
